@using WebAPP.Model
@model List<Shirt>

<h3>Shirts</h3>
<br/>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Brand</th>
            <th>Gender</th>
            <th>Size</th>
            <th>Color</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var shirt in Model)
        {
            <tr>
                <td>@shirt.Brand</td>
                <td>@shirt.Gender</td>
                <td>@shirt.Size</td>
                <td>@shirt.Color</td>
                <td>@(shirt.Price.HasValue ? shirt.Price.Value.ToString("C") : "N/A")</td>
            </tr>
        }
    </tbody>
</table>